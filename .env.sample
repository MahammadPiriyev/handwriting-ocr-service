# ===================== OCR (PDF render) =====================
DPI=300
VISION_RETRIES=4
VISION_TIMEOUT=60
MIN_OCR_CHARS=250
MIN_OCR_LINES=5
MAX_OCR_CHARS_PER_CHUNK=9000

# ===================== Google Vision OCR =====================
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ===================== Azure OpenAI (OCR cleanup) =====================
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15
AZURE_OPENAI_DEPLOYMENT=your_deployment_name_here

# ===================== Chatbot (gpt-oss-120b) =====================
CHAT_API_KEY=your_chat_api_key_here
CHAT_BASE_URL=https://your-chat-base-url.openai.azure.com/openai/v1
CHAT_MODEL=your_chat_model_name_here

# ===================== OpenRouter (Ministral OCR) =====================
OPENROUTER_API_URL=your_openrouter_api_url_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=your_openrouter_model_here

DB_HOST=your_db_host_here
DB_PORT=your_db_port_here
DB_NAME=your_db_name_here
DB_USER=your_db_user_here
DB_PASS=your_db_password_here